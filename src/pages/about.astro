---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`About Me | ${SITE_TITLE}`} description="Learn more about Luke Daniel." />
	</head>
	<body>
		<Header />
		<main>
			<h1 class="page-title">About Me</h1>
	<div class="about-container">
		<div class="headshot-column">
			<img src="/headshot.png" alt="Luke Daniel" class="headshot" />
			<div class="locations-wrapper">
				<div class="location-badge">
					<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
						<path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
						<circle cx="12" cy="10" r="3"></circle>
					</svg>
					New Jersey
				</div>
				<div class="location-badge">
					<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
						<path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
						<circle cx="12" cy="10" r="3"></circle>
					</svg>
					New York Metropolitan Area
				</div>
			</div>
		</div>
		<div class="bio">
			<p>
				Hi, I'm Luke Daniel. I'm a Data Science and Computer Science graduate from the University of Pittsburgh, currently working as a Software Engineer at VectorScribe, LLC. I'm passionate about building data-driven applications that solve real-world problems.
			</p>
			<p>
				With experience spanning full-stack development, machine learning, and data visualization, I enjoy building end-to-end solutions from data collection to deployment. Whether I'm analyzing sports statistics, building predictive models, or developing intuitive user interfaces, I'm driven by the goal of turning complex datasets into accessible and interactive user experiences.
			</p>
		</div>
	</div>

	<hr class="resume-divider" />

	<div class="resume-section">
		<h2>Education</h2>
		<div class="resume-item glass-card">
			<div class="resume-header">
				<h3>University of Pittsburgh</h3>
				<span class="resume-location">Pittsburgh, PA</span>
			</div>
			<div class="resume-subtitle-row">
				<div class="resume-subtitle">
					<strong>Bachelor of Science, Data Science & Computer Science</strong>
				</div>
				<span class="resume-date">August 2021 - May 2025</span>
			</div>
			<p class="resume-details">Magna Cum Laude | GPA: 3.75/4.00</p>
		</div>
	</div>

	<div class="resume-section">
		<h2>Skills</h2>
		<div class="resume-item glass-card skills-grid">
			<div class="skill-category">
				<strong>Languages & Frameworks</strong>
				<ul>
					<li>Python (+pandas)</li>
					<li>R (+ggplot2)</li>
					<li>Java</li>
					<li>SQL</li>
				</ul>
			</div>
			<div class="skill-category">
				<strong>Tools & Technologies</strong>
				<ul>
					<li>Microsoft Excel</li>
					<li>Looker Studio</li>
					<li>Claude Code</li>
				</ul>
			</div>
			<div class="skill-category">
				<strong>Core Competencies</strong>
				<ul>
					<li>Computer Programming</li>
					<li>Data Analysis</li>
				</ul>
			</div>
		</div>
	</div>

	<div class="resume-section">
		<h2>Relevant Experience</h2>
		
		<div class="resume-item glass-card">
			<div class="resume-header">
				<h3>VectorScribe, LLC</h3>
				<span class="resume-location">Bethlehem, PA</span>
			</div>
			<div class="resume-subtitle-row">
				<div class="resume-subtitle">
					<strong>Software Engineer</strong>
				</div>
				<span class="resume-date">August 2025 - Present</span>
			</div>
			<ul class="resume-bullets">
				<li>Developing a microprinter with applications including photonics and bioengineering.</li>
				<li>Managing and updating existing Python code.</li>
				<li>Creating a user interface to seamlessly interact with evolving hardware.</li>
			</ul>
		</div>

		<div class="resume-item glass-card">
			<div class="resume-header">
				<h3>Group Against Smog and Pollution (GASP)</h3>
				<span class="resume-location">Pittsburgh, PA</span>
			</div>
			<div class="resume-subtitle-row">
				<div class="resume-subtitle">
					<strong>Capstone Project Team Member</strong>
				</div>
				<span class="resume-date">January - April 2025</span>
			</div>
			<ul class="resume-bullets">
				<li>Built a dashboard to monitor steel facilities in Western Pennsylvania.</li>
				<li>Used Excel and Looker Studio for visualization and analysis of air quality violations.</li>
				<li>Worked in a team of students in collaboration with the non-profit organization.</li>
			</ul>
		</div>

		<div class="resume-item glass-card">
			<div class="resume-header">
				<h3>Advanced Data Management Technologies (ADMT) Laboratory</h3>
				<span class="resume-location">Pittsburgh, PA</span>
			</div>
			<div class="resume-subtitle-row">
				<div class="resume-subtitle">
					<strong>Student Researcher</strong>
				</div>
				<span class="resume-date">August - December 2024</span>
			</div>
			<ul class="resume-bullets">
				<li>Created an AI-based movie recommendation system using Python.</li>
				<li>Utilized OpenAI’s GPT to convert natural language into SQL queries.</li>
				<li>Built a system that reads input and returns results in natural language.</li>
			</ul>
		</div>

		<div class="resume-item glass-card">
			<div class="resume-header">
				<h3>NeuroTechR3</h3>
				<span class="resume-location">Newark, NJ</span>
			</div>
			<div class="resume-subtitle-row">
				<div class="resume-subtitle">
					<strong>Data Science Intern</strong>
				</div>
				<span class="resume-date">June - August 2023</span>
			</div>
			<ul class="resume-bullets">
				<li>Developed technology to rehabilitate patients with strokes and cerebral palsy.</li>
				<li>Participated in research on efficacy of product.</li>
				<li>Collected and organized research data in Microsoft Excel spreadsheets.</li>
			</ul>
		</div>
	</div>
		</main>
		<Footer />
	</body>
</html>

<style>
	.page-title {
		margin-bottom: 1em;
	}
	.about-container {
		display: flex;
		flex-direction: column;
		gap: 2em;
		margin-top: 1em;
	}
	.headshot-column {
		flex-shrink: 0;
		width: 100%;
		max-width: 300px;
		margin: 0 auto;
		display: flex;
		flex-direction: column;
		gap: 0.5em;
	}
	.headshot {
		width: 100%;
		height: auto;
		display: block;
		object-fit: cover;
		margin: 0 !important;
		border-radius: 12px;
		background: var(--bg-card);
		border: 4px solid var(--border-color);
		box-shadow: var(--box-shadow);
	}
	.bio p {
		margin-bottom: 1.5em;
		font-size: 1.1em;
		line-height: 1.8;
	}
	.locations-wrapper {
		display: flex;
		flex-direction: column;
		gap: 0.1em;
		margin-top: 0.5em;
	}
	.location-badge {
		display: inline-flex;
		align-items: center;
		gap: 0.4em;
		font-size: 0.95em;
		color: var(--text-muted);
		transition: color 0.2s ease;
	}
	.location-badge:hover {
		color: var(--text-main);
	}
	.location-badge:hover svg {
		stroke: var(--accent);
	}
	.location-badge svg {
		transition: stroke 0.2s ease;
	}
	@media (min-width: 768px) {
		.about-container {
			flex-direction: row;
			align-items: flex-start;
			gap: 3em;
		}
		.headshot-column {
			width: 250px;
			margin: 0;
		}
	}
	
	.resume-divider {
		border: 0;
		height: 1px;
		background: var(--border-color);
		margin: 3em 0;
	}
	.resume-section {
		margin-bottom: 3em;
	}
	.resume-section h2 {
		margin-bottom: 1em;
		font-size: 1.8em;
	}
	.resume-item {
		margin-bottom: 1.5em;
		padding: 1.5em 2em;
	}
	.resume-header {
		display: flex;
		justify-content: space-between;
		align-items: flex-start;
		flex-wrap: wrap;
		gap: 1em;
		margin-bottom: 0.2em;
	}
	.resume-header h3 {
		margin: 0;
		font-size: 1.3em;
		color: var(--text-main);
	}
	.resume-location {
		color: var(--text-main);
		font-size: 0.95em;
		font-weight: 500;
	}
	.resume-subtitle-row {
		display: flex;
		justify-content: space-between;
		align-items: flex-start;
		flex-wrap: wrap;
		gap: 1em;
		margin-bottom: 1em;
	}
	.resume-date {
		color: var(--text-muted);
		font-size: 0.9em;
	}
	.resume-subtitle {
		color: var(--accent);
		font-size: 1.05em;
		margin: 0;
	}
	.resume-details {
		margin: 0;
		color: var(--text-muted);
	}
	.resume-bullets {
		margin: 0;
		padding-left: 1.2em;
		color: var(--text-muted);
	}
	.resume-bullets li {
		margin-bottom: 0.5em;
		line-height: 1.6;
	}
	.skills-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
		gap: 2em;
	}
	.skill-category strong {
		display: block;
		color: var(--text-main);
		margin-bottom: 0.5em;
		font-size: 1.1em;
	}
	.skill-category ul {
		list-style: none;
		padding: 0;
		margin: 0;
	}
	.skill-category li {
		color: var(--text-muted);
		margin-bottom: 0.3em;
	}
	.skill-category li::before {
		content: '•';
		color: var(--accent);
		display: inline-block;
		width: 1em;
	}
</style>
