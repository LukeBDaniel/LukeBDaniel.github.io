---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<div class="hero">
				<div class="headshot-container">
					<!-- Replace this URL with your actual headshot image, e.g., "/headshot.jpg" once you add it to the public folder -->
					<img src="/headshot.png" alt="Luke Daniel" class="headshot" />
				</div>
				<div class="hero-text">
					<h1>Luke Daniel</h1>
					<p class="subtitle">
						A short collection of personal projects I have developed.
					</p>
				</div>
			</div>

			<section class="section">
				<h2>Projects</h2>
				<div class="projects-grid">
					<a href="/projects/gasp-violations" class="glass-card project-card">
						<h3>Visualizing Industrial Impact in Allegheny County</h3>
						<p>A data analytics capstone project for GASP (Group Against Smog & Pollution) visualizing 5 years of air quality violations and fines from major industrial polluters.</p>
					</a>
					<a href="/projects/sports-attendance" class="glass-card project-card">
						<h3>NY Sports Attendance Predictor</h3>
						<p>An interactive Machine Learning tool predicting home game attendance for major NY-area sports teams based on weather, form, and rivalries.</p>
					</a>
					<a href="/projects/amc-guide" class="glass-card project-card">
						<h3>AMC Guide</h3>
						<p>A web application with a custom scraper and React frontend for filtering and organizing AMC movie showtimes.</p>
					</a>
					<!-- Add more projects here in the future -->
				</div>
			</section>

			<section class="section">
				<h2>Articles</h2>
				<ul class="post-list">
					{
						posts.map((post) => (
							<li>
								<a href={`/blog/${post.slug}/`} class="glass-card">
									<span class="date">{post.data.pubDate.toLocaleDateString()}</span>
									<h3>{post.data.title}</h3>
									<p>{post.data.description}</p>
								</a>
							</li>
						))
					}
				</ul>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.hero {
		display: flex;
		align-items: center;
		gap: 3em;
		padding: 2em 0 3em 0;
		text-align: left;
	}
	.headshot-container {
		flex-shrink: 0;
		width: 200px;
		aspect-ratio: 4 / 5;
		border-radius: 12px;
		overflow: hidden;
		background: var(--bg-card);
		border: 4px solid var(--border-color);
		box-shadow: var(--box-shadow);
	}
	.headshot {
		width: 100%;
		height: 100%;
		object-fit: cover;
	}
	.hero-text h1 {
		margin-bottom: 0.25em;
	}
	.subtitle {
		font-size: 1.25em;
		color: var(--text-muted);
		max-width: 600px;
		margin: 0;
	}
	@media (max-width: 720px) {
		.hero {
			flex-direction: column;
			align-items: flex-start;
			gap: 2em;
		}
		.projects-grid {
			grid-template-columns: 1fr;
		}
	}
	.section {
		margin-bottom: 3em;
	}
	.projects-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(400px, 1fr));
		gap: 2em;
		margin-top: 1.5em;
	}
	.project-card {
		display: flex;
		flex-direction: column;
	}
	.project-card p, ul.post-list li p {
		margin: 0;
		color: var(--text-muted);
		font-size: 1.05em;
	}
	.btn {
		display: inline-block;
		font-weight: 600;
		color: var(--accent);
	}
	ul.post-list li a {
		text-decoration: none;
	}
	ul.post-list li a:hover h3 {
		color: var(--accent);
	}
</style>
